{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "types": ["node"],
    // Mirror the vitest alias so `tsc` typechecks against shared's source too.
    "paths": {
      "@osu-idle/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src", "vitest.config.ts"]
}
