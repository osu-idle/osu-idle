{
  "name": "@osu-idle/shared",
  "version": "0.12.4.0",
  "private": true,
  "type": "module",
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "lingui compile --typescript && tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "prepare": "tsc -p tsconfig.json",
    "extract": "lingui extract --clean",
    "compile": "lingui compile --typescript"
  },
  "dependencies": {
    "@lingui/core": "^5.9.5",
    "discord-api-types": "^0.38.49",
    "osu-classes": "^3.1.0",
    "osu-mania-stable": "^5.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@lingui/cli": "^5.9.5",
    "@lingui/conf": "^5.9.5",
    "typescript": "^5.6.3"
  }
}
