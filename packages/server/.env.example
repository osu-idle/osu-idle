# development | production. Drives the derived osu! redirect URI and Secure cookie.
NODE_ENV=development

# HTTP - dev and prod use separate ports so a running prod (systemd) service and
# a local `npm run dev` never collide. The server picks PORT when NODE_ENV is not
# production, and PORT_PROD when it is (the Apache vhost proxies to PORT_PROD).
PORT=3873
PORT_PROD=3874

# CORS / redirect target - the client app origin. Per-env (shared .env), so the
# server trusts CLIENT_URL when NODE_ENV is not production and CLIENT_URL_PROD when
# it is. Keeps prod from trusting the dev (localhost) origin.
CLIENT_URL=http://localhost:5173
CLIENT_URL_PROD=https://osu.idle.rhythmgamers.net

# MariaDB connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=osu_idle
DB_PASSWORD=change_me
DB_NAME=osu_idle

# osu! OAuth application (https://osu.ppy.sh/home/account/edit → OAuth).
# The callback URIs are derived from NODE_ENV (dev: http://localhost:PORT/...,
# prod: https://api.osu.idle.rhythmgamers.net/...) - register both on the app.
OSU_CLIENT_ID=change_me
OSU_CLIENT_SECRET=change_me

# Secret for signing session + CSRF-state JWTs (use a long random string).
JWT_SECRET=change_me
